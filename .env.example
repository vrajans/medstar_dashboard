# ── Copy this file to .env and fill in your values ──────────────────────────

# PostgreSQL connection strings
# asyncpg (used by FastAPI / SQLAlchemy async engine)
PG_DSN=postgresql+asyncpg://postgres:postgres@localhost:5432/medstar

# psycopg2 (used by migrate_to_pg.py -- sync)
# If omitted, migrate_to_pg.py derives it from PG_DSN automatically
# PG_DSN_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/medstar

# JWT settings
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINS=15
REFRESH_TOKEN_DAYS=7

# Dash app secret key (Flask session)
# FLASK_SECRET_KEY=change-this-too

# Default login credentials (only used on FIRST run when users table is empty)
# Change these before deploying to real users!
ADMIN_PASSWORD=MedStar@Admin#2026
VIEWER_PASSWORD=MedStar@View#2026

# FastAPI base URL (Dash calls this to get tenant data)
# Local:      http://127.0.0.1:8000
# Render.com: https://your-api-service.onrender.com
FASTAPI_BASE_URL=http://127.0.0.1:8000
