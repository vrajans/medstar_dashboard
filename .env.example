# =============================================================================
# InsightHub — Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# CORE APP
# ─────────────────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=insighthub-change-this-in-production-2026
APP_NAME=InsightHub
APP_URL=https://app.insighthub.ai
PORT=8050


# ─────────────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL (production)
PG_DSN=postgresql+asyncpg://postgres:postgres@localhost:5432/insighthub
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/insighthub

# FastAPI backend URL
API_BASE=https://your-fastapi-service.onrender.com

# JWT
JWT_SECRET_KEY=change-this-jwt-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7


# ─────────────────────────────────────────────────────────────────────────────
# PHASE 1 — ALERTS
# ─────────────────────────────────────────────────────────────────────────────

# SendGrid (Email)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@insighthub.ai

# Interakt (WhatsApp BSP — India)
INTERAKT_API_KEY=your-interakt-base64-api-key

# WATI (WhatsApp fallback)
WATI_API_KEY=your-wati-bearer-token
WATI_BASE_URL=https://live-mt-server.wati.io/XXXXX

# Twilio (SMS — USA / Global)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+14155238886

# Slack (Incoming Webhook)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00/B00/XXXX


# ─────────────────────────────────────────────────────────────────────────────
# PHASE 1 — SCHEDULER
# ─────────────────────────────────────────────────────────────────────────────
DIGEST_HOUR=8
WEEKLY_REPORT_DAY=mon
EXPIRY_WARN_DAYS=30
THRESHOLD_CHECK_HOURS=4


# ─────────────────────────────────────────────────────────────────────────────
# PHASE 1 — MARG ERP
# ─────────────────────────────────────────────────────────────────────────────
MARG_WATCH_DIR=/mnt/marg_exports
MARG_PROCESSED_DIR=/mnt/marg_processed
MARG_TENANT_MAP={}


# ─────────────────────────────────────────────────────────────────────────────
# PHASE 1 — BILLING
# ─────────────────────────────────────────────────────────────────────────────

# Razorpay (India INR)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
RAZORPAY_CALLBACK_URL=https://app.insighthub.ai/billing/razorpay/success

# Stripe (USA/Global USD)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret


# ─────────────────────────────────────────────────────────────────────────────
# PHASE 1 — MFA
# ─────────────────────────────────────────────────────────────────────────────
MFA_ISSUER=InsightHub Analytics
MFA_DIGITS=6
MFA_PERIOD=30


# ─────────────────────────────────────────────────────────────────────────────
# PHASE 2 — QUICKBOOKS OAUTH
# ─────────────────────────────────────────────────────────────────────────────
QB_CLIENT_ID=your-quickbooks-client-id
QB_CLIENT_SECRET=your-quickbooks-client-secret
QB_REDIRECT_URI=https://app.insighthub.ai/callback/quickbooks
QB_ENVIRONMENT=production


# ─────────────────────────────────────────────────────────────────────────────
# PHASE 2 — AI / RAG
# ─────────────────────────────────────────────────────────────────────────────
# Groq (free tier Llama 3.1) — get key from console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.1-70b-versatile

# ChromaDB
CHROMA_DIR=./chroma_db

# Embedding provider: ollama | openai | simple
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text

# OpenAI (alternative embeddings — paid)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

RAG_TOP_K=5


# ─────────────────────────────────────────────────────────────────────────────
# PHASE 2 — i18n
# ─────────────────────────────────────────────────────────────────────────────
DEFAULT_LANGUAGE=en
